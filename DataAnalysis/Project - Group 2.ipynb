    "def earnings_group_2024_value(x):\n",
    "    if pd.isna(x):\n",
    "        return np.nan\n",
    "    elif x < 15000:\n",
    "        return 1  # very low\n",
    "    elif x < 30000:\n",
    "        return 2  # low\n",
    "    elif x < 45000:\n",
    "        return 3  # lower-middle\n",
    "    elif x < 60000:\n",
    "        return 4  # middle\n",
    "    elif x < 80000:\n",
    "        return 5  # upper-middle\n",
    "    else:\n",
    "        return 6  # high\n",
    "\n",
    "\n",
    "df2['EARN_CAT_2024'] = df2['EARN_REAL_2024'].apply(earnings_group_2024_value)"
