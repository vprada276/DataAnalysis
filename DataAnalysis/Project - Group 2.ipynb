    "def education_level(code):\n",
    "    if 100 <= code <= 116:\n",
    "        return 0   # Did not graduate\n",
    "    elif 200 <= code <= 202:\n",
    "        return 1   # High School\n",
    "    elif 300 <= code <= 303:\n",
    "        return 2   # Some college (AA or similar)\n",
    "    elif code == 400:\n",
    "        return 3   # Bachelor's degree\n",
    "    elif 500 <= code <= 530:\n",
    "        return 4   # Master's or higher\n",
    "    elif code in [0, 996, 997, 998, 999]:\n",
    "        return np.nan  # NIU or unknown\n",
    "    else:\n",
    "        return np.nan  # anything else unexpected\n",
    "\n",
    "df['education_level'] = df['EDUC'].apply(education_level)"
