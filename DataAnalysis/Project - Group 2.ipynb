   "source": [
    "def gini(x):\n",
    "    x = np.sort(x)\n",
    "    n = len(x)\n",
    "    cumx = np.cumsum(x)\n",
    "    return (2 * np.sum((np.arange(1, n+1) * x)) / (n * cumx[-1])) - (n + 1) / n"
   ]
  },
